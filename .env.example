# Anthropic API Key
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# Optional: Clap detection sensitivity (default: 2500)
# Higher = less sensitive, Lower = more sensitive
CLAP_THRESHOLD=2500

# Optional: TTS engine - "pyttsx3" or "gtts" (default: pyttsx3)
TTS_ENGINE=pyttsx3

# Optional: Speech recognition language (default: ko-KR)
LANGUAGE=ko-KR
